# 基础路径配置
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SYNC_ON_STARTUP=true
SYNC_IN_BACKGROUND=true
LOG_DIR=./logs
ENABLE_AGENT_NODE_LOG=true
AGENT_NODE_LOG_LEVEL=INFO
RAW_DOC_PATH=./data/raw_docs
RAW_STRUCTURED_PATH=./data/raw_structured
CACHE_PATH=./data/parsed_cache
VECTOR_PERSIST_PATH=./data/persist_db
EVAL_RESULT_PATH=./eval/test_result
REPORT_OUTPUT_PATH=./data/reports

# LLM（全局默认；各阶段可单独覆盖 base_url / api_key / model / temperature，留空则继承全局）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=xxx
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
# Planner
# LLM_BASE_URL_PLANNER=
# LLM_API_KEY_PLANNER=
# LLM_MODEL_PLANNER=deepseek-chat
# LLM_TEMPERATURE_PLANNER=0.1
# Data（process_planner / data_processor）
# LLM_BASE_URL_DATA=
# LLM_API_KEY_DATA=
# LLM_MODEL_DATA=deepseek-chat
# LLM_TEMPERATURE_DATA=0.1
# Reporter
# LLM_BASE_URL_REPORTER=
# LLM_API_KEY_REPORTER=
# LLM_MODEL_REPORTER=deepseek-chat
# LLM_TEMPERATURE_REPORTER=0.1

# Embedding&Rerank
EMBED_MODEL_NAME=BAAI/bge-m3
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
DEVICE=cpu
# Hugging Face 镜像（国内推荐 hf-mirror.com；可直连时改为 https://huggingface.co）
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DOWNLOAD_TIMEOUT=120
# 模型缓存目录（建议放在空间充足的盘，如 D: 项目下的 data/hf_cache）
HF_HOME=./data/hf_cache

# 文档切块
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ES
ES_HOST=http://127.0.0.1:9200
ES_USER=elastic
ES_PASSWORD=elastic123
ES_INDEX_NAME=rag_chunk_index
ES_META_INDEX_NAME=rag_meta_index

# Chroma（推荐 Docker：docker compose up -d chroma → 127.0.0.1:8001）
# 镜像默认 ghcr.io/chroma-core/chroma:0.5.4（Docker Hub chromadb/chroma 国内常超时）
CHROMA_USE_HTTP=true
CHROMA_HTTP_HOST=127.0.0.1
CHROMA_HTTP_PORT=8001
CHROMA_COLLECTION=rag_collection
CHROMA_META_COLLECTION=rag_meta_collection
# 仅当 CHROMA_USE_HTTP=false 时使用本地持久化（Windows 上可能 HNSW 崩溃）
# VECTOR_PERSIST_PATH=./data/persist_db

# Redis 可选缓存
ENABLE_REDIS=false
REDIS_URL=redis://127.0.0.1:6379/0

# 前端 CORS
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# 文本检索（关键词 ES + 向量 Dense 双路融合，Reranker 精排过滤）
ENABLE_ES=true
ENABLE_DENSE=true
ES_WEIGHT=0.4
DENSE_WEIGHT=0.6
BASE_TOP_K=20
FINAL_TOP_K=10
MIN_RERANK_SCORE=0.65

# 结构化元数据检索
ENABLE_META_KEYWORD=true
ENABLE_META_DENSE=true
META_KEYWORD_WEIGHT=0.4
META_DENSE_WEIGHT=0.6
MAX_RETRIEVAL_ROUNDS=3
MAX_PLAN_TOOL_STEPS=1
# 为 true 时 planner 自动注入截断后的历史上下文，不再调用 load_history_context
PLANNER_AUTO_LOAD_HISTORY=true
PLANNER_HISTORY_CONTEXT_MAX_CHARS=800
MAX_PROCESS_TOOL_STEPS=20
MAX_REPORT_TOOL_STEPS=5
MAX_SQL_RETRIES=3
MAX_CONTEXT_TOOL_STEPS=5
CONTEXT_SIZE_THRESHOLD_CHARS=12000
PROCESSED_DATA_PREVIEW_ROWS=5
STRUCTURED_QUERY_MAX_ROWS=5000
CHART_TASK_TIMEOUT_SEC=120
LLM_DECISION_TIMEOUT_SEC=180
# 为 true 时服务就绪前阻塞加载 embed/rerank，避免首条请求与模型加载争抢
STARTUP_EMBED_WARMUP_BEFORE_READY=true
# LLM 热身：启动 ping 各角色 client；链路内 planner 并行 ping data、reporter 节点前 ping reporter
LLM_WARMUP_ENABLED=true
LLM_WARMUP_PIPELINE=true
LLM_WARMUP_TIMEOUT_SEC=15
